# ┌────────────────────────────────────────────┐
# │                 Start Script               │
# └────────────────────────────────────────────┘
animate_banner
neo_type "1;36" "Welcome to ArcHypr Setup Installer"
echo

# ┌────────────────────────────────────────────┐
# │          Start Prompt (Neo Style)          │
# └────────────────────────────────────────────┘
neo_type "1;93" "Do you want to start the setup? (y/n): "
read -r confirm

if [[ "$confirm" =~ ^[Yy]$ ]]; then
	flash_message "1;32" "✔ Starting Setup..."
elif [[ "$confirm" =~ ^[Nn]$ ]]; then
	flash_message "1;31" "✖ Setup Canceled."
	exit 0
else
	flash_message "1;33" "⚠ Invalid Input."
	exit 1
fi

# ┌────────────────────────────────────────────┐
# │      Start Yay Packages Install Setup      │
# └────────────────────────────────────────────┘
neo_type "1;34" "Installing YAY Package Manager  Bulid ..."
sleep 5

if ! command -v yay &>/dev/null; then
	echo "[2/6] Installing yay..."
	sudo pacman -S --needed git base-devel
	git clone https://aur.archlinux.org/yay.git
	cd yay && makepkg -si
	cd .. && rm -rf yay
fi

neo_type "1;34" "YAY Package Manager  Bulid done ..."
sleep 5

# ┌────────────────────────────────────────────┐
# │        installing Wallpaper Bank           │
# └────────────────────────────────────────────┘
neo_type "1;34" "Installing Wallpaper Bank ..."
sleep 3

mkdir -p ~/Pictures

if [ ! -d ~/Pictures/wallpaper ]; then
	git clone https://github.com/kntlifelovelive/bubuwallpaper.git ~/Pictures/wallpaper
	echo "Wallpaper installed successfully!"
else
	echo "Wallpaper folder already exists."
fi
neo_type "1;32" "Wallpaper-Bank  successfully!"

# ┌────────────────────────────────────────────┐
# │            Installing Packages             │
# └────────────────────────────────────────────┘
neo_type "1;34" "Installing Packages For Arch hyprland"
sleep 5

# ┌────────────────────────────────────────────┐
# │       Script Path Search Variable          │
# └────────────────────────────────────────────┘
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

neo_type "1;93" "Install Zsh + OhMyZsh Environment? (y/n): "
read -r zsh_confirm

if [[ "$zsh_confirm" =~ ^[Yy]$ ]]; then
	bash "$SCRIPT_DIR/scripts/install-zsh.sh"
fi

# ┌────────────────────────────────────────────┐
# │     Package pacman or Yay Install Script   │
# └────────────────────────────────────────────┘
bash "$SCRIPT_DIR/scripts/install-2packages.sh"

# ┌────────────────────────────────────────────┐
# │     font cache refresh Command run         │
# └────────────────────────────────────────────┘
neo_type "1;34" "font cache refresh"
sleep 5
fc-cache -fv
sleep 3
neo_type "1;34" "font cache refresh done !"
echo

# echo
# neo_type "1;34" "== Installed  Yay  Packages   =="
# sleep 5

# ┌────────────────────────────────────────────┐
# │            Yay Install Script              │
# └────────────────────────────────────────────┘
# bash "$SCRIPT_DIR/scripts/install-yay.sh"

# neo_type "1;34" "Installed Yay  Packages done !!"
# sleep 5

# ┌────────────────────────────────────────────┐
# │           Hypland Setup Configs            │
# └────────────────────────────────────────────┘
neo_type "1;34" "Hyprland Setup Configurations Start"
sleep 5
bash "$SCRIPT_DIR/scripts/archysetuproot.sh"

echo
neo_type "1;32" "✔ Arch Hyprland Config and Packages Install Complete!"
sleep 3

# ┌────────────────────────────────────────────┐
# │               Reload Hyprland              │
# └────────────────────────────────────────────┘
neo_type "1;36" "Reloading Hyprland..."
hyprctl reload 2>/dev/null || true
neo_type "1;32" "Hyprland reloaded successfully!"
sleep 3

# ┌────────────────────────────────────────────┐
# │               Victory Screen               │
# └────────────────────────────────────────────┘
victoryhyr

# ┌────────────────────────────────────────────┐
# │          Continue / Reboot Prompt          │
# └────────────────────────────────────────────┘
while true; do
	neo_type "1;93" "Do you want to continue (c) or reboot (r)? [c/r]: "
	read -r choice

	case "$choice" in
	[Cc]*)
		flash_message "1;32" "Continuing without reboot..."
		break
		;;
	[Rr]*)
		flash_message "1;31" "Rebooting now..."
		sudo reboot
		;;
	*)
		flash_message "1;33" "Please enter c or r."
		;;
	esac
done

clear
