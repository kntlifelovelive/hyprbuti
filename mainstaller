# ===============================
# Start Prompt (Neo Style)
# ===============================
neo_type "1;93" "Do you want to start the setup? (y/n): "
read -r confirm

if [[ "$confirm" =~ ^[Yy]$ ]]; then
	flash_message "1;32" "‚úĒ Starting Setup..."
elif [[ "$confirm" =~ ^[Nn]$ ]]; then
	flash_message "1;31" "‚úĖ Setup Canceled."
	exit 0
else
	flash_message "1;33" "‚ö† Invalid Input."
	exit 1
fi

