# ===============================
# Neon Typing Function
# ===============================
neo_type() {
	local color=$1
	local text="$2"
	local newline=${3:-yes}

	echo -ne "\033[${color}m"
	for ((i = 0; i < ${#text}; i++)); do
		printf "%s" "${text:$i:1}"
		sleep 0.05
	done

	if [[ "$newline" == "yes" ]]; then
		echo -e "\033[0m"
	else
		echo -ne "\033[0m"
	fi
}

# ===============================
# Flash Confirm Animation
# ===============================
flash_message() {
	local color=$1
	local message="$2"
	for i in {1..2}; do
		echo -ne "\r\033[${color}m${message}\033[0m"
		sleep 0.12
		echo -ne "\r                           "
		sleep 0.1
	done
	echo -e "\r\033[${color}m${message}\033[0m"
	sleep 0.3
	echo
}

