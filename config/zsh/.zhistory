my-netspeed() {\
 local speed=$(fast --single-line 2>/dev/null | xargs)\
 echo "My netspeed $speed"\
}\
\
#\
my-netspeed-icon() {\
 local speed=$(fast --single-line 2>/dev/null | xargs)\
 if [[ -n "$speed" ]]; then\
 echo "у°¤Ё My netspeed \e[1;33m$speed\e[0m"\
 else\
 echo "у°ѓҐѓ№ My netspeed \e[1;31mfailed\e[0m"\
 fi\
}\
\
