my-netspeed-icon() {\
 local speed=$(fast --single-line 2>/dev/null | xargs)\
 if [[ -n "$speed" ]]; then\
 echo "¾░ż© My netspeed \e[1;33m$speed\e[0m"\
 else\
 echo "¾░āźā╣ My netspeed \e[1;31mfailed\e[0m"\
 fi\
}\
